<%- include('./partials/header') %>

    <body>
        <%- include('./partials/menu', { activePage: 'users' , pageType: 'main' }) %>
            <link rel="stylesheet" href="/css/profile.css">
            <div class="container py-5">

                <div class="users-hero mb-5">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">

                        <div>
                            <h1 class="display-5 fw-bold mb-2">
                                <i class="bi bi-people-fill me-2"></i>
                                Community Members
                            </h1>

                            <p class="text-light-emphasis mb-0">
                                Explore our community and connect with
                                <strong>
                                    <%= users.length %>
                                </strong> members.
                            </p>
                        </div>

                        <div class="d-flex gap-3 flex-wrap align-items-center">
                            <div class="search-box">
                                <label class="small text-muted mb-1 d-block">
                                    Find a user
                                </label>
                                <div class="input-group">
                                    <input type="text" id="search" class="form-control" placeholder="Search users...">
                                    <button class="btn btn-primary"><i class="fa fa-search"></i></button>
                                </div>
                            </div>

                            <div>
                                <label class="small text-muted mb-1 d-block">
                                    Users per page
                                </label>

                                <select id="pageSize" class="form-select">
                                    <option value="5">5</option>
                                    <option value="10" selected>10</option>
                                    <option value="20">20</option>
                                </select>
                            </div>

                            <div>
                                <label class="small text-muted mb-1 d-block">
                                    Sort by
                                </label>

                                <select id="usersSort" class="form-select">
                                    <option value="recent" selected>Recent</option>
                                    <option value="name">Name A-Z</option>
                                    <option value="followers">Followers</option>
                                    <option value="following">Following</option>
                                </select>
                            </div>

                        </div>

                    </div>
                </div>

                <div class="row g-4" id="user-card">

                    <% users.forEach(user=> { %>
                        <div class="col-md-6 col-xl-4" data-pagination-item
                            data-search="<%= [user.username, user.displayName || '', user.bio || ''].join(' ').toLowerCase() %>"
                            data-sort-recent="<%= new Date(user.createdAt).getTime() %>"
                            data-sort-name="<%= (user.displayName || user.username).toLowerCase() %>"
                            data-sort-followers="<%= user.followers?.length || 0 %>"
                            data-sort-following="<%= user.following?.length || 0 %>">
                            <div class="user-card p-4">
                                <div class="d-flex gap-3">
                                    <img src="<%= user.profilePicture %>" alt="<%= user.username %>"
                                        class="user-avatar">
                                    <div>
                                        <a href="/users/<%= user._id %>" class="user-username">
                                            <%= user.displayName || user.username %>
                                        </a>
                                        <div class="text-muted small">
                                            @<%= user.username %>
                                        </div>
                                    </div>
                                </div>
                                <% if(user.bio){ %>
                                    <div class="user-bio">
                                        <%= user.bio.length> 120 ? user.bio.substring(0,120) + '...' : user.bio %>
                                    </div>
                                    <% } else {%>
                                        <div class="user-bio text-muted">
                                            No bio available.
                                        </div>
                                        <% } %>
                                            <div class="user-stats">
                                                <span>
                                                    <strong>
                                                        <%= user.followers?.length || 0 %>
                                                    </strong>
                                                    followers
                                                </span>
                                                <span>
                                                    <strong>
                                                        <%= user.following?.length || 0 %>
                                                    </strong>
                                                    following
                                                </span>
                                            </div>

                                            <div class="user-footer">Joined <%= user.createdAt.toLocaleDateString() %>
                                            </div>

                            </div>
                        </div>
                        <% }) %>

                            <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                                <span id="usersInfo" class="text-muted small"></span>
                                <ul class="pagination justify-content-end mb-0" id="usersPagination"></ul>
                            </div>

                            <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    new Pagination({
                                        container: '#user-card',
                                        pagination: '#usersPagination',
                                        search: '#search',
                                        pageSize: '#pageSize',
                                        sortSelect: '#usersSort',
                                        info: '#usersInfo',
                                        defaultSort: 'recent',
                                        emptyMessage: 'Nenhum usuário encontrado.',
                                        sorters: {
                                            recent: {
                                                sort: function (a, b) {
                                                    return Number(b.dataset.sortRecent || 0) - Number(a.dataset.sortRecent || 0);
                                                }
                                            },
                                            name: {
                                                sort: function (a, b) {
                                                    return (a.dataset.sortName || '').localeCompare(b.dataset.sortName || '', 'pt-BR');
                                                }
                                            },
                                            followers: {
                                                sort: function (a, b) {
                                                    return Number(b.dataset.sortFollowers || 0) - Number(a.dataset.sortFollowers || 0);
                                                }
                                            },
                                            following: {
                                                sort: function (a, b) {
                                                    return Number(b.dataset.sortFollowing || 0) - Number(a.dataset.sortFollowing || 0);
                                                }
                                            }
                                        }
                                    });
                                });
                            </script>

                </div>
            </div>
            <%- include('./partials/footer') %>
    </body>