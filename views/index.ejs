<%- include('./partials/header') %>

    <body class="">
        <%- include('./partials/menu', { activePage: 'index' , pageType: 'main' }) %>
            <div class="main-content">
                <h2 class="display-6 d-inline">Top Questions</h2>
                <a class="btn float-end btn-primary" href="/questions/ask">Ask Question</a>
                <div class="filters">
                    <a href="#" class="active">Newest</a>
                    <a href="#">Active</a>
                    <a href="#">Unanswered</a>
                    <a href="#">More</a>
                </div>

                <div class="question-list">
                    <% questions.forEach((question) => { %>
                    <article class="question-item border-bottom p-3 d-flex gap-5">
                        <div class="question-stats d-flex flex-column gap-2 text-center">
                            <span class="text-muted"><%= question.upvotes %> votes</span> 
                            <span class="text-muted"><%= question.downvotes %> downvotes</span>
                            <span class="text-muted"><%= question.views %> views</span>
                        </div>
                        <div class="question-details">
                            <a href="/questions/<%= question._id %>" class="h4 text-decoration-none text-dark"><%= question.title %></a>
                            <div class="tags">
                                <% question.tags.forEach(function(tag) { %>
                                    <span class="badge bg-secondary"><%= tag.name %></span>
                                <% }); %>
                            </div>
                            <p class="question-meta text-muted">Asked by <a href="/users/<%= question.creator._id %>"><%= question.creator.username %></a> on <%= question.createdAt.toLocaleDateString() %></p>
                        </div>
                    </article>
                    <% }) %>
                </div>
                <p class="mt-4 text-center fs-5 fw-semibold">
                    Want to see all questions? <a href="/questions" class="text-decoration-none">Click here</a>
                </p>
    </body>

    <%- include('./partials/footer') %>