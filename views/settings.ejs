<%- include('./partials/header') %>

<body>
    <%- include('./partials/menu', { activePage: 'settings', pageType: 'main' }) %>
    <main class="content-area">
        <div class="container-fluid px-2 px-md-4">
            <div class="row g-4">
                <!-- Page Header -->
                <section class="col-12">
                    <div class="mb-4">
                        <h1 class="h4 mb-2">Settings</h1>
                        <p class="text-secondary mb-0">Manage your account preferences and settings</p>
                    </div>
                </section>

                <div class="col-12">
                    <div class="row g-4">
                        <!-- Sidebar Navigation -->
                        <div class="col-12 col-md-3">
                            <div class="card border-0 shadow-sm" style="position: sticky; top: 74px;">
                                <div class="list-group list-group-flush">
                                    <button class="list-group-item list-group-item-action text-start settings-tab active" data-tab="profile">
                                        <i class="bi bi-person me-2"></i> Profile
                                    </button>
                                    <button class="list-group-item list-group-item-action text-start settings-tab" data-tab="account">
                                        <i class="bi bi-shield-lock me-2"></i> Account
                                    </button>
                                    <button class="list-group-item list-group-item-action text-start settings-tab" data-tab="notifications">
                                        <i class="bi bi-bell me-2"></i> Notifications
                                    </button>
                                    <button class="list-group-item list-group-item-action text-start settings-tab" data-tab="preferences">
                                        <i class="bi bi-sliders me-2"></i> Preferences
                                    </button>
                                    <button class="list-group-item list-group-item-action text-start settings-tab" data-tab="privacy">
                                        <i class="bi bi-eye-slash me-2"></i> Privacy
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Settings Content -->
                        <div class="col-12 col-md-9">
                            <!-- Profile Tab -->
                            <div class="settings-content active" id="profile-tab">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">Profile Information</h5>
                                        
                                        <form>
                                            <!-- Avatar Section -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <label class="form-label fw-500">Avatar</label>
                                                <div class="d-flex align-items-center gap-3">
                                                    <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #f48024, #f0883e); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 2rem;">
                                                        JD
                                                    </div>
                                                    <div>
                                                        <input type="file" class="form-control form-control-sm" accept="image/*" style="max-width: 200px;">
                                                        <small class="text-secondary d-block mt-2">JPG, GIF or PNG. Max size of 2MB</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Display Name -->
                                            <div class="mb-3">
                                                <label for="displayName" class="form-label">Display Name</label>
                                                <input type="text" class="form-control" id="displayName" value="John Developer" placeholder="Your display name">
                                                <small class="text-secondary">This is the name displayed on your profile</small>
                                            </div>

                                            <!-- Username -->
                                            <div class="mb-3">
                                                <label for="username" class="form-label">Username</label>
                                                <div class="input-group">
                                                    <span class="input-group-text">@</span>
                                                    <input type="text" class="form-control" id="username" value="johndev" placeholder="username">
                                                </div>
                                                <small class="text-secondary">Your unique identifier on the platform</small>
                                            </div>

                                            <!-- Email -->
                                            <div class="mb-3">
                                                <label for="email" class="form-label">Email</label>
                                                <input type="email" class="form-control" id="email" value="john.developer@example.com" placeholder="your@email.com">
                                                <small class="text-secondary">We'll never share your email with anyone</small>
                                            </div>

                                            <!-- Bio -->
                                            <div class="mb-3">
                                                <label for="bio" class="form-label">About Me</label>
                                                <textarea class="form-control" id="bio" rows="4" placeholder="Tell us about yourself...">Full-stack developer passionate about JavaScript and clean code.</textarea>
                                                <small class="text-secondary">Max 500 characters</small>
                                            </div>

                                            <!-- Location -->
                                            <div class="mb-3">
                                                <label for="location" class="form-label">Location</label>
                                                <input type="text" class="form-control" id="location" value="São Paulo, Brazil" placeholder="Where are you from?">
                                            </div>

                                            <!-- Website -->
                                            <div class="mb-4">
                                                <label for="website" class="form-label">Website</label>
                                                <input type="url" class="form-control" id="website" value="https://johndeveloper.dev" placeholder="https://example.com">
                                            </div>

                                            <button type="submit" class="btn b-primary">Save Changes</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Account Tab -->
                            <div class="settings-content" id="account-tab" style="display: none;">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">Account Security</h5>
                                        
                                        <form>
                                            <!-- Current Password -->
                                            <div class="mb-3 pb-4 border-bottom">
                                                <label for="currentPassword" class="form-label fw-500">Change Password</label>
                                                <div class="mb-3">
                                                    <label for="currentPassword" class="form-label">Current Password</label>
                                                    <input type="password" class="form-control" id="currentPassword" placeholder="Enter your current password">
                                                </div>

                                                <!-- New Password -->
                                                <div class="mb-3">
                                                    <label for="newPassword" class="form-label">New Password</label>
                                                    <input type="password" class="form-control" id="newPassword" placeholder="Enter new password">
                                                    <small class="text-secondary">At least 8 characters</small>
                                                </div>

                                                <!-- Confirm Password -->
                                                <div class="mb-3">
                                                    <label for="confirmPassword" class="form-label">Confirm Password</label>
                                                    <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm your password">
                                                </div>

                                                <button type="button" class="btn btn-outline-secondary">Update Password</button>
                                            </div>

                                            <!-- Two Factor Auth -->
                                            <div class="mb-4 pt-4">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-1">Two-Factor Authentication</h6>
                                                        <p class="text-secondary small mb-0">Add an extra layer of security to your account</p>
                                                    </div>
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="twoFactorAuth">
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Active Sessions -->
                                            <div class="mb-4">
                                                <h6 class="mb-3">Active Sessions</h6>
                                                <div class="border rounded p-3 mb-2">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <div class="fw-500">Chrome on MacOS</div>
                                                            <small class="text-secondary">Last active: 2 minutes ago</small>
                                                        </div>
                                                        <button type="button" class="btn btn-sm btn-outline-danger">Sign Out</button>
                                                    </div>
                                                </div>
                                                <div class="border rounded p-3">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <div class="fw-500">Safari on iPhone</div>
                                                            <small class="text-secondary">Last active: 1 hour ago</small>
                                                        </div>
                                                        <button type="button" class="btn btn-sm btn-outline-danger">Sign Out</button>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Danger Zone -->
                                            <div class="mt-4 pt-4 border-top border-danger">
                                                <h6 class="text-danger mb-3">Danger Zone</h6>
                                                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">Delete Account</button>
                                                <small class="text-secondary d-block mt-2">Once you delete your account, there is no going back. Please be certain.</small>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Notifications Tab -->
                            <div class="settings-content" id="notifications-tab" style="display: none;">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">Notification Preferences</h5>
                                        
                                        <form>
                                            <!-- Email Notifications -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <h6 class="mb-3">Email Notifications</h6>
                                                
                                                <div class="mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="answerNotification" checked>
                                                        <label class="form-check-label" for="answerNotification">
                                                            <strong>New Answers</strong>
                                                            <p class="text-secondary small mb-0">Get notified when someone answers your questions</p>
                                                        </label>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="commentNotification" checked>
                                                        <label class="form-check-label" for="commentNotification">
                                                            <strong>New Comments</strong>
                                                            <p class="text-secondary small mb-0">Get notified when someone comments on your posts</p>
                                                        </label>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="mentionNotification" checked>
                                                        <label class="form-check-label" for="mentionNotification">
                                                            <strong>Mentions</strong>
                                                            <p class="text-secondary small mb-0">Get notified when someone mentions you</p>
                                                        </label>
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="reputationNotification">
                                                        <label class="form-check-label" for="reputationNotification">
                                                            <strong>Reputation Changes</strong>
                                                            <p class="text-secondary small mb-0">Get a weekly summary of your reputation changes</p>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- In-App Notifications -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <h6 class="mb-3">In-App Notifications</h6>
                                                
                                                <div class="mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="inAppAll" checked>
                                                        <label class="form-check-label" for="inAppAll">
                                                            <strong>Enable all in-app notifications</strong>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Email Frequency -->
                                            <div class="mb-4">
                                                <label for="emailFrequency" class="form-label">Email Frequency</label>
                                                <select class="form-select" id="emailFrequency">
                                                    <option selected>Whenever something happens</option>
                                                    <option>Daily digest</option>
                                                    <option>Weekly digest</option>
                                                    <option>Never</option>
                                                </select>
                                            </div>

                                            <button type="submit" class="btn b-primary">Save Preferences</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Preferences Tab -->
                            <div class="settings-content" id="preferences-tab" style="display: none;">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">General Preferences</h5>
                                        
                                        <form>
                                            <!-- Language -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <label for="language" class="form-label">Language</label>
                                                <select class="form-select" id="language">
                                                    <option selected>Portuguese (Brasil)</option>
                                                    <option>English</option>
                                                    <option>Spanish</option>
                                                    <option>French</option>
                                                    <option>German</option>
                                                </select>
                                            </div>

                                            <!-- Theme -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <label class="form-label">Theme</label>
                                                <div class="btn-group d-flex gap-2" role="group">
                                                    <input type="radio" class="btn-check" name="theme" id="lightTheme" checked>
                                                    <label class="btn btn-outline-secondary" for="lightTheme">
                                                        <i class="bi bi-sun me-2"></i>Light
                                                    </label>

                                                    <input type="radio" class="btn-check" name="theme" id="darkTheme">
                                                    <label class="btn btn-outline-secondary" for="darkTheme">
                                                        <i class="bi bi-moon-stars me-2"></i>Dark
                                                    </label>

                                                    <input type="radio" class="btn-check" name="theme" id="autoTheme">
                                                    <label class="btn btn-outline-secondary" for="autoTheme">
                                                        <i class="bi bi-circle-half me-2"></i>Auto
                                                    </label>
                                                </div>
                                            </div>

                                            <!-- Homepage -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <label for="homepage" class="form-label">Default Homepage</label>
                                                <select class="form-select" id="homepage">
                                                    <option selected>Newest</option>
                                                    <option>Hot</option>
                                                    <option>Top</option>
                                                    <option>Active</option>
                                                </select>
                                            </div>

                                            <!-- Content -->
                                            <div class="mb-4">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="explicitContent" checked>
                                                    <label class="form-check-label" for="explicitContent">
                                                        Show explicit content
                                                    </label>
                                                </div>

                                                <div class="form-check mt-2">
                                                    <input class="form-check-input" type="checkbox" id="highQuality" checked>
                                                    <label class="form-check-label" for="highQuality">
                                                        Reduced animations (better performance)
                                                    </label>
                                                </div>

                                                <div class="form-check mt-2">
                                                    <input class="form-check-input" type="checkbox" id="compactMode">
                                                    <label class="form-check-label" for="compactMode">
                                                        Compact display
                                                    </label>
                                                </div>
                                            </div>

                                            <button type="submit" class="btn b-primary">Save Preferences</button>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Privacy Tab -->
                            <div class="settings-content" id="privacy-tab" style="display: none;">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">Privacy Settings</h5>
                                        
                                        <form>
                                            <!-- Profile Visibility -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <label for="profileVisibility" class="form-label">Profile Visibility</label>
                                                <select class="form-select" id="profileVisibility">
                                                    <option value="public" selected>Public</option>
                                                    <option value="private">Private</option>
                                                    <option value="friends">Community Members Only</option>
                                                </select>
                                                <small class="text-secondary">Controls who can view your profile</small>
                                            </div>

                                            <!-- Activity Status -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <div class="fw-500">Show your activity status</div>
                                                        <small class="text-secondary">Let others see when you're online</small>
                                                    </div>
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="activityStatus" checked>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Show Email -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <div class="fw-500">Show email publicly</div>
                                                        <small class="text-secondary">Allow anyone to see your email address</small>
                                                    </div>
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="showEmail">
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Social Profiles -->
                                            <div class="mb-4 pb-4 border-bottom">
                                                <h6 class="mb-3">Social Links</h6>
                                                
                                                <div class="mb-3">
                                                    <label for="github" class="form-label">GitHub</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text">
                                                            <i class="bi bi-github"></i>
                                                        </span>
                                                        <input type="text" class="form-control" id="github" placeholder="github.com/username" value="github.com/johndev">
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label for="twitter" class="form-label">Twitter (X)</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text">@</span>
                                                        <input type="text" class="form-control" id="twitter" placeholder="username" value="johndev">
                                                    </div>
                                                </div>

                                                <div class="mb-3">
                                                    <label for="linkedin" class="form-label">LinkedIn</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text">
                                                            <i class="bi bi-linkedin"></i>
                                                        </span>
                                                        <input type="text" class="form-control" id="linkedin" placeholder="linkedin.com/in/username" value="linkedin.com/in/johndeveloper">
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Blocked Users -->
                                            <div class="mb-4">
                                                <h6 class="mb-3">Blocked Users</h6>
                                                <p class="text-secondary small mb-3">Users you have blocked will not be able to contact you or see your posts</p>
                                                <button type="button" class="btn btn-outline-secondary btn-sm">Manage Blocked Users</button>
                                            </div>

                                            <button type="submit" class="btn b-primary">Save Privacy Settings</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Delete Account Modal -->
    <div class="modal fade" id="deleteAccountModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title">Delete Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2"><strong>Are you sure you want to delete your account?</strong></p>
                    <p class="text-secondary small mb-3">This action cannot be undone. All your data including posts, comments, and messages will be permanently deleted.</p>
                    <div class="alert alert-warning" role="alert">
                        <small><strong>Warning:</strong> This will also remove all your contributions to the community.</small>
                    </div>
                    <label class="form-label">Type your username to confirm:</label>
                    <input type="text" class="form-control" placeholder="johndev">
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger">Delete My Account</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const tabs = document.querySelectorAll('.settings-tab');
            const contents = document.querySelectorAll('.settings-content');

            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    const tabName = this.getAttribute('data-tab');
                    
                    // Remove active class from all
                    tabs.forEach(t => t.classList.remove('active'));
                    contents.forEach(c => c.style.display = 'none');
                    
                    // Add active class to clicked tab
                    this.classList.add('active');
                    document.getElementById(tabName + '-tab').style.display = 'block';
                });
            });
        });
    </script>

    <style>
        .settings-tab {
            border-left: 3px solid transparent !important;
            transition: all 0.15s ease;
        }

        .settings-tab:hover {
            background-color: var(--hover) !important;
        }

        .settings-tab.active {
            border-left-color: var(--accent) !important;
            background-color: var(--active) !important;
            color: #0c0d0e !important;
            font-weight: 600;
        }

        .form-check-label {
            cursor: pointer;
        }

        .btn-group .btn {
            flex: 1;
            white-space: nowrap;
        }

        @media (max-width: 768px) {
            .card {
                margin-bottom: 1rem;
            }

            .settings-tab {
                text-align: center;
            }

            .form-control, .form-select {
                font-size: 16px; /* Prevents zoom on iOS */
            }
        }

        /* Smoothed animations */
        .settings-content {
            animation: fadeIn 0.15s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</body>

<%- include('./partials/footer') %>
