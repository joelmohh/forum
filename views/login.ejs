<%- include('./partials/header') %>
<body class="auth-page">
    <%- include('./partials/menu', { activePage: 'login', pageType: 'auth' }) %>
    <main class="auth-shell">
        <div class="row g-0 justify-content-center">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                <div class="card auth-card p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="auth-subtitle mx-auto mb-0">Use your email and password to continue.</p>
                    </div>
                    
                    <form class="auth-form">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" placeholder="you@example.com">
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" placeholder="Your password">
                        </div>

                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 small">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="remember">
                                <label class="form-check-label" for="remember">Remember me</label>
                            </div>
                            <a href="#" class="link-secondary text-decoration-none">Forgot password?</a>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-dark btn-lg w-100 d-flex align-items-center justify-content-center">Log in</button>
                        </div>

                        <p class="text-center text-secondary small mt-3 mb-0">
                            Don't have an account? <a href="/signup" class="link-secondary fw-semibold text-decoration-none">Sign up</a>
                        </p>
                    </form>
                    <div class="text-center mb-4">
                        <p class="auth-subtitle mx-auto mb-0 auth-divider"><span></span>or <span></span></p>
                    </div>
                    <div class="text-center mb-4 social-auth-container">
                        <button class="social-auth google-auth" type="button">
                            <i class="bi bi-google" aria-hidden="true"></i>
                            <span class="social-auth-label">Continue with Google</span>
                            <span aria-hidden="true"></span>
                        </button>
                        <button class="social-auth microsoft-auth" type="button">
                            <i class="bi bi-microsoft" aria-hidden="true"></i>
                            <span class="social-auth-label">Continue with Microsoft</span>
                            <span aria-hidden="true"></span>
                        </button>
                        <button class="social-auth github-auth" type="button">
                            <i class="bi bi-github" aria-hidden="true"></i>
                            <span class="social-auth-label">Continue with GitHub</span>
                            <span aria-hidden="true"></span>
                        </button>
                    </div>
                    
                </div>
            </div>
        </div>
    </main>
</body>

<%- include('./partials/footer') %>