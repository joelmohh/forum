<%- include('./partials/header') %>

<body>
    <%- include('./partials/menu', { activePage: 'tags', pageType: 'main' }) %>

    <div class="container py-5">

        <div class="tags-hero mb-5">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
                <div>
                    <h1 class="display-5 fw-bold mb-2">
                        <i class="bi bi-tags-fill me-2"></i>
                        Tags
                    </h1>
                    <p class="text-light-emphasis mb-0">
                        Explore our <strong><%= tags.length %></strong> tags and discover the topics that interest you.
                    </p>
                </div>

                <div class="d-flex gap-3 flex-wrap align-items-center">
                    <div class="search-box">
                        <label class="small text-muted mb-1 d-block">Find a tag</label>
                        <div class="input-group">
                            <input type="text" id="tagsSearch" class="form-control" placeholder="Search tags...">
                            <button class="btn btn-primary"><i class="fa fa-search"></i></button>
                        </div>
                    </div>

                    <div>
                        <label class="small text-muted mb-1 d-block">Tags per page</label>
                        <select id="tagsPageSize" class="form-select">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="filters">
            <a href="#" class="active" data-pagination-sort="popular">Popular</a>
            <a href="#" data-pagination-sort="name">Name</a>
            <a href="#" data-pagination-sort="new">New</a>
        </div>

        <div class="tag-list mt-4" id="tagsList">
            <div class="row g-4">

                <% tags.forEach(tag => { %>
                    <div class="col-sm-6 col-lg-4 col-xl-3" data-pagination-item
                        data-search="<%= tag.name.toLowerCase() %>"
                        data-sort-popular="<%= Number(tag.questionCount || 0) + Number(tag.followerCount || 0) %>"
                        data-sort-name="<%= tag.name.toLowerCase() %>"
                        data-sort-new="<%= new Date(tag.createdAt).getTime() %>">
                        <div class="card h-100 border">
                            <div class="card-body">
                                <span class="badge text-bg-warning text-decoration-none mb-3"><%= tag.name %></span>

                                <div class="row text-center">
                                    <div class="col">
                                        <div class="fw-semibold"><%= tag.questionCount %></div>
                                        <small class="text-muted">Questions</small>
                                    </div>

                                    <div class="col">
                                        <div class="fw-semibold"><%= tag.followerCount %></div>
                                        <small class="text-muted">Followers</small>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                <% }) %>

            </div>

            <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                <ul class="pagination justify-content-end mb-0" id="tagsPagination"></ul>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new Pagination({
                container: '#tagsList .row',
                pagination: '#tagsPagination',
                search: '#tagsSearch',
                pageSize: '#tagsPageSize',
                filters: '[data-pagination-sort]',
                defaultSort: 'popular',
                emptyMessage: 'Nenhuma tag encontrada.',
                sorters: {
                    popular: {
                        sort: function (a, b) {
                            return Number(b.dataset.sortPopular || 0) - Number(a.dataset.sortPopular || 0);
                        }
                    },
                    name: {
                        sort: function (a, b) {
                            return (a.dataset.sortName || '').localeCompare(b.dataset.sortName || '', 'pt-BR');
                        }
                    },
                    new: {
                        sort: function (a, b) {
                            return Number(b.dataset.sortNew || 0) - Number(a.dataset.sortNew || 0);
                        }
                    }
                }
            });
        });
    </script>

    <%- include('./partials/footer') %>