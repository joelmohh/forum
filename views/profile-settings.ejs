<%- include('./partials/header') %>

    <body>
        <div id="toast-container"></div>
        <%- include('./partials/menu', { activePage: 'profile-settings' , pageType: 'main' }) %>

            <div class="container py-5">
                <div class="row">

                    <!-- LEFT -->
                    <div class="col-lg-3 mb-4">

                        <div class="card shadow-sm mb-3">
                            <div class="card-body text-center">

                                <img src="<%= user.profilePicture || '/img/default-avatar.png' %>"
                                    class="rounded-circle mb-3" width="110" height="110">

                                <h5 class="mb-0">
                                    <%= user.displayName || user.username %>
                                </h5>
                                <small class="text-muted">@<%= user.username %></small>

                            </div>
                        </div>


                    </div>

                    <!-- RIGHT -->
                    <div class="col-lg-9">

                        <div id="profileForm">

                            <!-- PROFILE -->
                            <div class="card shadow-sm mb-4" id="profile">
                                <div class="card-body">

                                    <h4 class="mb-4">Profile</h4>

                                    <!-- DISPLAY NAME -->
                                    <div class="mb-3">
                                        <label class="form-label">Display Name</label>

                                        <input type="text" class="form-control" id="displayName" name="displayName"
                                            value="<%= user.displayName || '' %>">

                                        <div class="validation-messages" id="displayName-message"></div>
                                    </div>

                                    <!-- PROFILE PICTURE -->
                                    <div class="mb-3">
                                        <label class="form-label">Profile Picture</label>

                                        <input type="file" class="form-control" id="profilePicture"
                                            name="profilePicture" accept="image/png,image/jpeg,image/webp,image/gif">

                                        <div class="validation-messages" id="profilePicture-message"></div>

                                        <button type="button" class="btn btn-outline-danger btn-sm mt-2"
                                            id="removeProfilePicture">
                                            Remove Profile Picture
                                        </button>
                                    </div>

                                    <!-- BANNER -->
                                    <div class="mb-4">

                                        <label class="form-label fw-semibold">Profile Banner</label>

                                        <!-- PREVIEW -->
                                        <div id="bannerPreview"
                                            class="rounded border overflow-hidden position-relative mb-3"
                                            style="height:180px; cursor:pointer; background:<%= user.bannerColor || '#000000' %>;">

                                            <% if (user.banner) { %>
                                                <img id="bannerPreviewImage" src="<%= user.banner %>"
                                                    class="w-100 h-100 object-fit-cover">
                                                <% } else { %>
                                                    <img id="bannerPreviewImage"
                                                        class="w-100 h-100 object-fit-cover d-none">
                                                    <% } %>

                                                        <div class="position-absolute top-50 start-50 translate-middle
                    bg-dark bg-opacity-50 text-white px-3 py-2 rounded">
                                                            <i class="fa-solid fa-image me-2"></i>
                                                            Click to change banner
                                                        </div>
                                        </div>

                                        <!-- INPUT FILE (HIDDEN) -->
                                        <input type="file" id="banner" name="banner" class="d-none"
                                            accept="image/png,image/jpeg,image/webp,image/gif">

                                        <div class="validation-messages mb-3" id="banner-message"></div>

                                        <button type="button" class="btn btn-outline-danger btn-sm mb-3"
                                            id="removeBanner">
                                            Remove Banner
                                        </button>

                                        <div class="row">

                                            <div class="col-md-4">
                                                <label class="form-label">Banner Color</label>

                                                <input type="color" class="form-control form-control-color"
                                                    id="bannerColor" name="bannerColor"
                                                    value="<%= user.bannerColor || '#000000' %>">

                                                <div class="validation-messages" id="bannerColor-message"></div>
                                            </div>

                                            <div class="col-md-8">
                                                <label class="form-label">Selected file</label>

                                                <div id="bannerFileName" class="form-control">
                                                    <%= user.banner ? 'Current banner selected' : 'No file selected' %>
                                                </div>

                                                <small class="text-muted">
                                                    PNG, JPG, WEBP or GIF • Max 5MB • Recommended 1500×500
                                                </small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- BIO -->
                                    <div class="mb-3">
                                        <label class="form-label">Bio</label>

                                        <textarea class="form-control" rows="4" id="bio" name="bio"
                                            maxlength="500"><%= user.bio || '' %></textarea>

                                        <div class="validation-messages" id="bio-message"></div>
                                    </div>

                                </div>
                            </div>

                            <!-- SECURITY -->
                            <div class="card shadow-sm mb-4">

                                <div class="card-body">

                                    <h4 class="mb-4">Security</h4>

                                    <!-- OLD PASSWORD -->
                                    <div class="input-group mb-3">
                                        <input type="password" class="form-control" id="oldPassword"
                                            placeholder="Current password">

                                        <button type="button" class="btn btn-primary togglePassword">
                                            <i class="fa-regular fa-eye"></i>
                                        </button>
                                    </div>
                                    <div id="oldPassword-message" class="validation-messages mb-3"></div>

                                    <!-- NEW PASSWORD -->
                                    <div class="input-group mb-2">
                                        <input type="password" class="form-control" id="newPassword"
                                            placeholder="New password">

                                        <button type="button" class="btn btn-primary togglePassword">
                                            <i class="fa-regular fa-eye"></i>
                                        </button>
                                    </div>

                                    <div id="newPassword-message" class="validation-messages mb-3"></div>

                                    <!-- PASSWORD (EXTRA OPTIONAL FIELD) -->
                                    <div class="input-group mb-2">
                                        <input type="password" class="form-control" id="password" name="password"
                                            placeholder="New password">

                                        <button type="button" class="btn btn-primary togglePassword">
                                            <i class="fa-regular fa-eye"></i>
                                        </button>
                                    </div>

                                    <div id="password-message" class="validation-messages mb-3"></div>

                                </div>

                            </div>

                            <!-- SAVE -->
                            <div class="d-flex justify-content-end mb-4">
                                <button type="button" id="saveProfileBtn" class="btn btn-primary px-4">
                                    Save Changes
                                </button>
                            </div>

                        </div>
                        <div class="card shadow-sm mb-4" id="devices">
                            <div class="card-body">

                                <div class="d-flex justify-content-between align-items-center mb-4">

                                    <div>
                                        <h4 class="mb-1">
                                            <i class="fa-solid fa-laptop me-2"></i>
                                            Devices
                                        </h4>
                                        <small class="text-muted">
                                            Manage active sessions across your devices.
                                        </small>
                                    </div>

                                    <button type="button" class="btn btn-outline-danger" id="revokeAllSessions">
                                        Sign Out All Devices
                                    </button>

                                </div>

                                <% const activeDevices=(devices || []).filter(d=> !d.revoked);
                                    const revokedDevices = (devices || []).filter(d => d.revoked);
                                    %>

                                    <% if (activeDevices.length> 0) { %>

                                        <div class="d-flex flex-column gap-3">

                                            <% activeDevices.forEach((device)=> { %>

                                                <div class="border rounded p-3">

                                                    <div
                                                        class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                                                        <div class="flex-grow-1">

                                                            <div class="fw-semibold mb-1">
                                                                <i class="fa-solid fa-desktop me-2"></i>
                                                                <%= device.userAgent %>
                                                            </div>

                                                            <div class="small text-muted">
                                                                <i class="fa-solid fa-globe me-1"></i>
                                                                <%= device.ip %>
                                                            </div>

                                                            <div class="small text-muted">
                                                                <i class="fa-regular fa-clock me-1"></i>
                                                                Last activity:
                                                                <%= device.lastUsedAt.toLocaleString() %>
                                                            </div>

                                                        </div>

                                                        <div class="text-end">

                                                            <div
                                                                class="d-flex flex-wrap gap-2 justify-content-end mb-2">

                                                                <% if (device.isCurrent) { %>
                                                                    <span class="badge bg-primary">
                                                                        Current Device
                                                                    </span>
                                                                    <% } %>

                                                                        <span class="badge bg-success">
                                                                            Active
                                                                        </span>

                                                            </div>

                                                            <% if (!device.isCurrent) { %>
                                                                <button
                                                                    class="btn btn-sm btn-outline-danger revoke-session-btn"
                                                                    data-session-id="<%= device.id %>">
                                                                    Revoke
                                                                </button>
                                                                <% } %>

                                                        </div>

                                                    </div>

                                                </div>

                                                <% }); %>

                                        </div>

                                        <% } else { %>

                                            <div class="text-center py-4">
                                                <i class="fa-solid fa-laptop-slash fs-1 text-muted mb-3"></i>
                                                <p class="text-muted mb-0">
                                                    No active devices found.
                                                </p>
                                            </div>

                                            <% } %>

                                                <!-- DISPOSITIVOS DESCONECTADOS (ESCONDIDOS) -->
                                                <% if (revokedDevices.length> 0) { %>

                                                    <hr class="my-4">

                                                    <button
                                                        class="btn btn-light w-100 d-flex justify-content-between align-items-center border"
                                                        type="button" data-bs-toggle="collapse"
                                                        data-bs-target="#revokedDevicesCollapse" aria-expanded="false"
                                                        aria-controls="revokedDevicesCollapse">
                                                        <span>
                                                            <i class="fa-solid fa-clock-rotate-left me-2"></i>
                                                            Signed-out devices (<%= revokedDevices.length %>)
                                                        </span>
                                                        <i class="fa-solid fa-chevron-down"></i>
                                                    </button>

                                                    <div class="collapse mt-3" id="revokedDevicesCollapse">

                                                        <div class="d-flex flex-column gap-3">

                                                            <% revokedDevices.forEach((device)=> { %>

                                                                <div class="border rounded p-3 bg-light bg-opacity-50">

                                                                    <div
                                                                        class="d-flex justify-content-between align-items-start flex-wrap gap-3">

                                                                        <div class="flex-grow-1">

                                                                            <div class="fw-semibold mb-1 text-muted">
                                                                                <i class="fa-solid fa-desktop me-2"></i>
                                                                                <%= device.userAgent %>
                                                                            </div>

                                                                            <div class="small text-muted">
                                                                                <i class="fa-solid fa-globe me-1"></i>
                                                                                <%= device.ip %>
                                                                            </div>

                                                                            <div class="small text-muted">
                                                                                <i class="fa-regular fa-clock me-1"></i>
                                                                                Last activity:
                                                                                <%= device.lastUsedAt.toLocaleString()
                                                                                    %>
                                                                            </div>

                                                                        </div>

                                                                        <div class="text-end">
                                                                            <span class="badge bg-danger">
                                                                                Revoked
                                                                            </span>
                                                                        </div>

                                                                    </div>

                                                                </div>

                                                                <% }); %>

                                                        </div>

                                                    </div>

                                                    <% } %>

                            </div>
                        </div>
                        <div class="card shadow-sm mb-4" id="securityActivity">
                            <div class="card-body">

                                <div class="mb-4">
                                    <h4 class="mb-1">
                                        <i class="fa-solid fa-shield-halved me-2"></i>
                                        Security Activity
                                    </h4>
                                    <small class="text-muted">
                                        Recent security events on your account.
                                    </small>
                                </div>

                                <% if (activityLogs.length) { %>

                                    <div class="d-flex flex-column gap-3">

                                        <% activityLogs.forEach(log=> { %>

                                            <div class="border rounded p-3">

                                                <div class="d-flex justify-content-between align-items-start">

                                                    <div>

                                                        <div class="fw-semibold">
                                                            <% switch(log.type) { case "login" : %>
                                                                <i
                                                                    class="fa-solid fa-right-to-bracket text-success me-2"></i>
                                                                Successful sign in
                                                                <% break; case "logout" : %>
                                                                    <i
                                                                        class="fa-solid fa-right-from-bracket text-secondary me-2"></i>
                                                                    Signed out
                                                                    <% break; case "password_change" : %>
                                                                        <i
                                                                            class="fa-solid fa-key text-warning me-2"></i>
                                                                        Password changed
                                                                        <% break; case "profileUpdate" : %>
                                                                            <i
                                                                                class="fa-solid fa-user-pen text-primary me-2"></i>
                                                                            Profile updated
                                                                            <% break; case "logout" : %>
                                                                                <i
                                                                                    class="fa-solid fa-shield-halved text-muted me-2"></i>
                                                                                Logout
                                                                                <% } %>
                                                        </div>

                                                        <div class="small text-muted mt-1">
                                                            <i class="fa-solid fa-globe me-1"></i>
                                                            <%= log.ipAddress %>
                                                        </div>

                                                        <div class="small text-muted">
                                                            <i class="fa-solid fa-desktop me-1"></i>
                                                            <%= log.userAgent %>
                                                        </div>

                                                    </div>

                                                    <div class="text-end small text-muted">
                                                        <%= log.timestamp.toLocaleString() %>
                                                    </div>

                                                </div>

                                            </div>

                                            <% }) %>

                                    </div>

                                    <% } else { %>

                                        <div class="text-center py-4">
                                            <i class="fa-solid fa-shield-halved fs-1 text-muted mb-3"></i>
                                            <p class="text-muted mb-0">
                                                No security activity recorded.
                                            </p>
                                        </div>

                                        <% } %>

                            </div>
                        </div>
                    </div>

                </div>

            </div>

            <script src="/js/profileUpdate.js"></script>

            <%- include('./partials/footer') %>

    </body>