<%- include('./partials/header') %>

<body>

<%- include('./partials/menu', { activePage: 'profile-settings', pageType: 'main' }) %>

<div class="container py-5">

    <div class="row">

        <!-- LEFT PROFILE CARD -->
        <div class="col-lg-3 mb-4">

            <div class="card shadow-sm mb-3">
                <div class="card-body text-center">

                    <img src="<%= user.profilePicture || '/img/default-avatar.png' %>"
                         class="rounded-circle mb-3"
                         width="110" height="110">

                    <h5 class="mb-0">
                        <%= user.displayName || user.username %>
                    </h5>

                    <small class="text-muted">
                        @<%= user.username %>
                    </small>

                </div>
            </div>

            <!-- SETTINGS MENU -->
            <div class="card shadow-sm">
                <div class="list-group list-group-flush">

                    <a href="#profile" class="list-group-item list-group-item-action active">
                        Profile
                    </a>

                    <a href="#account" class="list-group-item list-group-item-action">
                        Account
                    </a>

                    <a href="#security" class="list-group-item list-group-item-action">
                        Security
                    </a>

                    <a href="#devices" class="list-group-item list-group-item-action">
                        Devices
                    </a>

                </div>
            </div>

        </div>

        <!-- RIGHT CONTENT -->
        <div class="col-lg-9">

            <form action="/settings/profile" method="POST">

                <!-- PROFILE -->
                <div class="card shadow-sm mb-4" id="profile">
                    <div class="card-body">

                        <h4 class="mb-4">Profile</h4>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input type="text" class="form-control" name="username"
                                   value="<%= user.username %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" name="displayName"
                                   value="<%= user.displayName || '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Profile Picture URL</label>
                            <input type="url" class="form-control" name="profilePicture"
                                   value="<%= user.profilePicture || '' %>">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="4" maxlength="500"
                                      name="bio"><%= user.bio || '' %></textarea>

                            <small class="text-muted">
                                Max 500 characters
                            </small>
                        </div>

                    </div>
                </div>

                <!-- ACCOUNT -->
                <div class="card shadow-sm mb-4" id="account">
                    <div class="card-body">

                        <h4 class="mb-4">Account</h4>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email"
                                   value="<%= user.email %>">
                        </div>

                    </div>
                </div>

                <!-- SECURITY -->
                <div class="card shadow-sm mb-4" id="security">
                    <div class="card-body">

                        <h4 class="mb-4">Security</h4>

                        <div class="mb-3">
                            <input type="password" class="form-control"
                                   name="currentPassword"
                                   placeholder="Current password">
                        </div>

                        <div class="mb-3">
                            <input type="password" class="form-control"
                                   name="newPassword"
                                   placeholder="New password">
                        </div>

                        <div>
                            <input type="password" class="form-control"
                                   name="confirmPassword"
                                   placeholder="Confirm new password">
                        </div>

                    </div>
                </div>

                <!-- SAVE BUTTON -->
                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary px-4">
                        Save Changes
                    </button>
                </div>

            </form>

<!-- DEVICES -->
<div class="card shadow-sm mt-4" id="devices">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0">Connected Devices</h4>
            <small class="text-muted">
                Sessions linked to your account
            </small>
        </div>

        <% devices.forEach(device => { %>

            <div class="border rounded p-3 mb-3 d-flex justify-content-between align-items-start">

                <!-- LEFT -->
                <div class="d-flex gap-3">

                    <!-- ICON -->
                    <div class="fs-3">

                        <% if (device.userAgent.toLowerCase().includes('mobile')) { %>
                            📱
                        <% } else if (device.userAgent.toLowerCase().includes('windows') || device.userAgent.toLowerCase().includes('mac')) { %>
                            💻
                        <% } else { %>
                            🖥️
                        <% } %>

                    </div>

                    <!-- INFO -->
                    <div>

                        <div class="fw-semibold">
                            <%= device.userAgent %>
                        </div>

                        <div class="text-muted small">
                            IP: <%= device.ip %>
                        </div>

                        <div class="text-muted small">
                            Last active: <%= device.lastUsedAt.toLocaleString() %>
                        </div>

                        <div class="mt-2">
                            <span class="badge bg-<%= device.revoked ? 'danger' : 'success' %>">
                                <%= device.revoked ? 'Revoked' : 'Active' %>
                            </span>

                            <% if (device.isCurrent) { %>
                                <span class="badge bg-secondary">
                                    Current session
                                </span>
                            <% } %>
                        </div>

                    </div>

                </div>

                <!-- ACTION -->
                <div>

                    <% if (!device.revoked) { %>
                        <button class="btn btn-sm btn-outline-danger">
                            Log out of this device
                        </button>
                    <% } else { %>
                        <small class="text-muted">Not logged in</small>
                    <% } %>

                </div>

            </div>

        <% }) %>

    </div>

</div>

        </div>

    </div>

</div>

<script src="/js/session.js"></script>

<%- include('./partials/footer') %>

</body>