<%- include('./partials/header') %>

    <body>

        <%- include('./partials/menu', { pageType: 'main' , activePage: 'users' }) %>
            <link rel="stylesheet" href="/css/profile.css">
            <link rel="stylesheet" href="/css/prism.css">
            <script src="/js/prism.js"></script>
            <div class="container py-4" style="max-width:780px">

                <!-- PROFILE CARD -->
                <div class="profile-wrapper">

                    <div class="profile-banner">
                        <% if (displayUser.banner && !displayUser.banner.endsWith('800x200')) { %>
                            <img src="<%= displayUser.banner %>" alt="Banner">
                            <% } %>
                    </div>

                    <div class="profile-body">

                        <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap:12px">

                            <img src="<%= displayUser.profilePicture %>" alt="<%= displayUser.username %>'s avatar"
                                class="avatar-ring">

                            <% if(isSelf===false && isSelf.toString() !==displayUser._id.toString()){ %>
                                <button id="followBtn" class="btn-follow" data-user-id="<%= displayUser._id %>"
                                    data-following="<%= following ? 'true' : 'false' %>" style="margin-top:12px">
                                    <%- following ? '<i class="fa-solid fa-user-minus"></i> Unfollow'
                                        : '<i class="fa-solid fa-user-plus"></i> Follow' %>
                                </button>
                                <% } else {%>
                                    <a href="/users/<%= displayUser._id %>/settings" class="btn btn-outline-primary"
                                        style="margin-top:12px">
                                        <i class="fa-solid fa-user-pen"></i> Edit Profile
                                    </a>
                                    <% } %>

                        </div>

                        <div class="profile-header-row">
                            <div>
                                <h1 class="profile-name">
                                    <%= displayUser.displayName || displayUser.username %>
                                        <% if(displayUser.verified){ %>
                                            <i class="fa-solid fa-circle-check verified-badge"></i>
                                            <% } %>
                                </h1>
                                <div class="profile-handle">@<%= displayUser.username %>
                                </div>
                            </div>
                        </div>

                        <p class="profile-bio">
                            <%= displayUser.bio || 'This user hasn\' t added a bio yet.' %>
                        </p>

                        <div class="profile-stats">
                            <div class="stat-item">
                                <strong>
                                    <%= questions.length %>
                                </strong>
                                <span>Questions</span>
                            </div>
                            <div class="stat-item">
                                <strong>
                                    <%= answers.length %>
                                </strong>
                                <span>Answers</span>
                            </div>
                            <div class="stat-item">
                                <strong id="followersCount">
                                    <%= displayUser.followers.length %>
                                </strong>
                                <span>Followers</span>
                            </div>
                            <div class="stat-item">
                                <strong>
                                    <%= displayUser.following.length %>
                                </strong>
                                <span>Following</span>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- TABS -->
                <div class="tabs-row">
                    <button class="tab-btn active" data-target="questions">
                        Questions <span class="tab-count">
                            <%= questions.length %>
                        </span>
                    </button>
                    <button class="tab-btn" data-target="answers">
                        Answers <span class="tab-count">
                            <%= answers.length %>
                        </span>
                    </button>
                </div>

                <!-- Questions -->
                <div class="tab-pane active" id="questions">

                    <% if(questions && questions.length){ %>

                        <% questions.forEach(question=> { %>
                            <div class="card-item">

                                <div class="d-flex justify-content-between align-items-start" style="gap:12px">
                                    <div style="flex:1">
                                        <a href="/questions/<%= question._id %>">
                                            <h5>
                                                <%= question.title %>
                                            </h5>
                                        </a>
                                        <div class="card-meta">
                                            <% if(question.tags){ %>
                                                <span class="category-pill">
                                                    <%= question.tags[0].name %>
                                                </span>
                                                <span>·</span>
                                                <% } %>
                                                    <span>
                                                        <%= new Date(question.createdAt).toLocaleDateString('en-US', {
                                                            month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                                    </span>
                                        </div>
                                    </div>
                                    <% if(question.isPinned){ %>
                                        <span class="pinned-badge">
                                            <i class="fa-solid fa-thumbtack"></i> Pinned
                                        </span>
                                        <% } %>
                                </div>

                                <div class="card-excerpt">
                                    <%- question.content %>
                                </div>

                                <div class="card-footer-row">
                                    <span class="card-stat">
                                        <i class="fa-solid fa-arrow-up"></i>
                                        <%= question.score %>
                                    </span>
                                    <span class="card-stat">
                                        <i class="fa-regular fa-answers"></i>
                                        <%= question.answersCount %>
                                            <span style="font-weight:400;color:#9ca3af">replies</span>
                                    </span>
                                </div>

                            </div>
                            <% }) %>

                                <% } else { %>
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="fa-regular fa-file-lines"></i></div>
                                        <h6>No questions yet</h6>
                                        <p>This user hasn't published anything.</p>
                                    </div>
                                    <% } %>
                </div>

                <!-- answers -->
                <div class="tab-pane" id="answers">

                    <% if(answers && answers.length> 0){ %>

                        <% answers.forEach(answers=> { %>
                            <div class="card-item">

                                <% if(answers.question){ %>
                                    <div class="answers-origin">
                                        <i class="fa-regular fa-answers-dots"></i>
                                        Answered on
                                        <a href="/questions/<%= answers.question._id %>">
                                            <%= answers.question.title %>
                                        </a>
                                    </div>
                                    <% } %>

                                        <p class="answers-text">
                                            <%- answers.content %>
                                        </p>

                                        <div class="card-footer-row">
                                            <span class="card-stat">
                                                <i class="fa-solid fa-arrow-up"></i>
                                                <%= answers.score %>
                                            </span>
                                            <span class="card-stat" style="font-weight:400;color:#9ca3af">
                                                <%= new Date(answers.createdAt).toLocaleDateString('en-US', {
                                                    month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                            </span>
                                        </div>

                            </div>
                            <% }) %>

                                <% } else { %>
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="fa-regular fa-answers"></i></div>
                                        <h6>No answers yet</h6>
                                        <p>This user hasn't commented on anything.</p>
                                    </div>
                                    <% } %>
                </div>

            </div>

            <script>
                /* ── Tabs ── */
                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
                        btn.classList.add('active');
                        document.getElementById(btn.dataset.target).classList.add('active');
                    });
                });
            </script>
            <script src="/js/profile.js"></script>

            <%- include('./partials/footer') %>

    </body>