<%- include('./partials/header') %>

    <body>

        <%- include('./partials/menu', { pageType: 'main' , activePage: 'users' }) %>
        <link rel="stylesheet" href="/css/profile.css">

            <div class="container py-4" style="max-width:780px">

                <!-- PROFILE CARD -->
                <div class="profile-wrapper">

                    <div class="profile-banner"></div>

                    <div class="profile-body">

                        <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap:12px">

                            <img src="<%= displayUser.profilePicture %>" alt="<%= displayUser.username %>'s avatar"
                                class="avatar-ring">

                            <% if(currentUser && currentUser._id.toString() !==displayUser._id.toString()){ %>
                                <button id="followBtn" data-user-id="<%= displayUser._id %>" class="btn-follow"
                                    style="margin-top:12px">
                                    Follow
                                </button>
                                <% } %>

                        </div>

                        <div class="profile-header-row">
                            <div>
                                <h1 class="profile-name">
                                    <%= displayUser.displayName || displayUser.username %>
                                        <% if(displayUser.verified){ %>
                                            <i class="fa-solid fa-circle-check verified-badge"></i>
                                            <% } %>
                                </h1>
                                <div class="profile-handle">@<%= displayUser.username %>
                                </div>
                            </div>
                        </div>

                        <p class="profile-bio">
                            <%= displayUser.bio || 'This user hasn\' t added a bio yet.' %>
                        </p>

                        <div class="profile-stats">
                            <div class="stat-item">
                                <strong>
                                    <%= posts.length %>
                                </strong>
                                <span>Posts</span>
                            </div>
                            <div class="stat-item">
                                <strong>
                                    <%= comments.length %>
                                </strong>
                                <span>Comments</span>
                            </div>
                            <div class="stat-item">
                                <strong>
                                    <%= displayUser.followers.length %>
                                </strong>
                                <span>Followers</span>
                            </div>
                            <div class="stat-item">
                                <strong>
                                    <%= displayUser.following.length %>
                                </strong>
                                <span>Following</span>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- TABS -->
                <div class="tabs-row">
                    <button class="tab-btn active" data-target="posts">
                        Posts <span class="tab-count">
                            <%= posts.length %>
                        </span>
                    </button>
                    <button class="tab-btn" data-target="comments">
                        Comments <span class="tab-count">
                            <%= comments.length %>
                        </span>
                    </button>
                </div>

                <!-- POSTS -->
                <div class="tab-pane active" id="posts">

                    <% if(posts && posts.length){ %>

                        <% posts.forEach(post=> { %>
                            <div class="card-item">

                                <div class="d-flex justify-content-between align-items-start" style="gap:12px">
                                    <div style="flex:1">
                                        <a href="/posts/<%= post.slug %>">
                                            <h5>
                                                <%= post.title %>
                                            </h5>
                                        </a>
                                        <div class="card-meta">
                                            <% if(post.tags){ %>
                                                <span class="category-pill">
                                                    <%= post.tags[0].name %>
                                                </span>
                                                <span>·</span>
                                                <% } %>
                                                    <span>
                                                        <%= new Date(post.createdAt).toLocaleDateString('en-US', {
                                                            month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                                    </span>
                                        </div>
                                    </div>
                                    <% if(post.isPinned){ %>
                                        <span class="pinned-badge">
                                            <i class="fa-solid fa-thumbtack"></i> Pinned
                                        </span>
                                        <% } %>
                                </div>

                                <p class="card-excerpt">
                                    <%= post.content.length> 300
                                        ? post.content.substring(0, 300) + '…'
                                        : post.content
                                        %>
                                </p>

                                <div class="card-footer-row">
                                    <span class="card-stat">
                                        <i class="fa-solid fa-arrow-up"></i>
                                        <%= post.score %>
                                    </span>
                                    <span class="card-stat">
                                        <i class="fa-regular fa-comment"></i>
                                        <%= post.answersCount %>
                                            <span style="font-weight:400;color:#9ca3af">replies</span>
                                    </span>
                                </div>

                            </div>
                            <% }) %>

                                <% } else { %>
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="fa-regular fa-file-lines"></i></div>
                                        <h6>No posts yet</h6>
                                        <p>This user hasn't published anything.</p>
                                    </div>
                                    <% } %>
                </div>

                <!-- COMMENTS -->
                <div class="tab-pane" id="comments">

                    <% if(comments && comments.length){ %>

                        <% comments.forEach(comment=> { %>
                            <div class="card-item">

                                <% if(comment.post){ %>
                                    <div class="comment-origin">
                                        <i class="fa-regular fa-comment-dots"></i>
                                        Commented on
                                        <a href="/posts/<%= comment.post.slug %>">
                                            <%= comment.post.title %>
                                        </a>
                                    </div>
                                    <% } %>

                                        <p class="comment-text">
                                            <%= comment.content %>
                                        </p>

                                        <div class="card-footer-row">
                                            <span class="card-stat">
                                                <i class="fa-solid fa-arrow-up"></i>
                                                <%= comment.score %>
                                            </span>
                                            <span class="card-stat" style="font-weight:400;color:#9ca3af">
                                                <%= new Date(comment.createdAt).toLocaleDateString('en-US', {
                                                    month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                            </span>
                                        </div>

                            </div>
                            <% }) %>

                                <% } else { %>
                                    <div class="empty-state">
                                        <div class="empty-icon"><i class="fa-regular fa-comments"></i></div>
                                        <h6>No comments yet</h6>
                                        <p>This user hasn't commented on anything.</p>
                                    </div>
                                    <% } %>
                </div>

            </div>

            <script>
                /* ── Tabs ── */
                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
                        btn.classList.add('active');
                        document.getElementById(btn.dataset.target).classList.add('active');
                    });
                });

                /* ── Follow ── */
                document.getElementById('followBtn')
                    ?.addEventListener('click', async function () {
                        const btn = this;
                        try {
                            const res = await fetch(`/users/${btn.dataset.userId}/follow`, {
                                method: 'POST',
                                credentials: 'include'
                            });
                            if (res.ok) {
                                btn.classList.add('following');
                                btn.textContent = 'Following';
                            }
                        } catch (err) {
                            console.error(err);
                        }
                    });
            </script>

            <%- include('./partials/footer') %>

    </body>