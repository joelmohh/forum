<%- include('./partials/header') %>

    <body class="">
        <%- include('./partials/menu', { activePage: 'questions' , pageType: 'main' }) %>
            <div class="container py-5">

                <div class="questions-hero mb-5">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
                        <div>
                            <h1 class="display-5 fw-bold mb-2">
                                <i class="bi bi-question-circle-fill me-2"></i>
                                All Questions
                            </h1>
                            <p class="text-light-emphasis mb-0">
                                Browse through
                                <strong><%= questions.length %></strong> questions asked by our community.
                            </p>
                        </div>

                        <div class="d-flex gap-3 flex-wrap align-items-center">
                            <div class="search-box">
                                <label class="small text-muted mb-1 d-block">Find a question</label>
                                <div class="input-group">
                                    <input type="text" id="questionsSearch" class="form-control"
                                        placeholder="Search questions...">
                                    <button class="btn btn-primary"><i class="fa fa-search"></i></button>
                                </div>
                            </div>

                            <div>
                                <label class="small text-muted mb-1 d-block">Questions per page</label>
                                <select id="questionsPageSize" class="form-select">
                                    <option value="5">5</option>
                                    <option value="10" selected>10</option>
                                    <option value="20">20</option>
                                    <option value="50">50</option>
                                </select>
                            </div>

                            <div>
                                <label class="small text-muted mb-1 d-block invisible">Booo</label>
                                <a class="btn btn-primary" href="/questions/ask">Ask Question</a>
                            </div>
                            
                        </div>
                    </div>
                </div>

                <div class="filters">
                    <a href="#" class="active" data-pagination-sort="newest">Newest</a>
                    <a href="#" data-pagination-sort="active">Active</a>
                    <a href="#" data-pagination-sort="unanswered">Unanswered</a>
                </div>

                <div class="question-list mt-3" id="questionsList">
                    <% questions.forEach((question)=> { %>
                        <article class="question-item border-bottom p-3 d-flex gap-5" data-pagination-item
                            data-search="<%= [question.title, question.creator.username, question.creator.displayName || '', question.tags.map(function(tag) { return tag.name; }).join(' ')].join(' ').toLowerCase() %>"
                            data-sort-newest="<%= new Date(question.createdAt).getTime() %>"
                            data-sort-active="<%= new Date(question.updatedAt || question.createdAt).getTime() %>"
                            data-answers-count="<%= question.answersCount || 0 %>">
                            <div class="question-stats d-flex flex-column gap-2 text-center">
                                <span class="text-muted">
                                    <%= question.score %> votes
                                </span>
                                <span class="text-muted">
                                    <%= question.answersCount || 0 %> answers
                                </span>
                                <span class="text-muted">
                                    <%= question.viewCount || 0 %> views
                                </span>
                            </div>
                            <div class="question-details">
                                <a href="/questions/<%= question._id %>" class="h4 text-decoration-none text-dark">
                                    <%= question.title %>
                                </a>
                                <div class="tags">
                                    <% question.tags.forEach(function(tag) { %>
                                        <span class="badge bg-secondary">
                                            <%= tag.name %>
                                        </span>
                                        <% }); %>
                                </div>
                                <p class="question-meta text-muted">Asked by 
                                        <a href="/users/<%= question.creator.username %>">
                                        <%= question.creator.username %>
                                    </a> on <%= question.createdAt.toLocaleDateString() %>
                                </p>
                            </div>
                        </article>
                        <% }) %>

                </div>

                <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                    <ul class="pagination justify-content-end mb-0" id="questionsPagination"></ul>
                </div>

                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        new Pagination({
                            container: '#questionsList',
                            pagination: '#questionsPagination',
                            search: '#questionsSearch',
                            pageSize: '#questionsPageSize',
                            filters: '[data-pagination-sort]',
                            defaultSort: 'newest',
                            emptyMessage: 'No questions found.',
                            sorters: {
                                newest: {
                                    sort: function (a, b) {
                                        return Number(b.dataset.sortNewest || 0) - Number(a.dataset.sortNewest || 0);
                                    }
                                },
                                active: {
                                    sort: function (a, b) {
                                        return Number(b.dataset.sortActive || 0) - Number(a.dataset.sortActive || 0);
                                    }
                                },
                                unanswered: {
                                    filter: function (item) {
                                        return Number(item.dataset.answersCount || 0) === 0;
                                    },
                                    sort: function (a, b) {
                                        return Number(b.dataset.sortNewest || 0) - Number(a.dataset.sortNewest || 0);
                                    }
                                }
                            }
                        });
                    });
                </script>
            </div>
    </body>

    <%- include('./partials/footer') %>