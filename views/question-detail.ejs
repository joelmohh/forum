<%- include('./partials/header') %>

    <body>
        <%- include('./partials/menu', { activePage: 'questions' , pageType: 'main' }) %>

            <style>
                /* layout base */
                .page-wrap {
                    max-width: 1100px;
                    margin: 0 auto;
                }

                /* content readability */
                .question-content,
                .answer-content {
                    font-size: 1.05rem;
                    line-height: 1.8;
                }

                .question-content p,
                .answer-content p {
                    margin-bottom: 1rem;
                }

                .question-content pre,
                .answer-content pre {
                    background: #0d1117;
                    border: 1px solid #30363d;
                    color: #fff;
                    padding: 1.25rem;
                    border-radius: 10px;
                    overflow-x: auto;
                }

                /* vote */
                .vote-box {
                    position: sticky;
                    top: 90px;
                }

                .vote-btn {
                    width: 48px;
                    height: 48px;
                    border-radius: 50%;
                }

                /* user card */
                .user-mini {
                    background: #f8f9fa;
                    border: 1px solid #dee2e6;
                    border-radius: 10px;
                    padding: 12px;
                    min-width: 220px;
                }

                /* answer separation */
                .answer-item {
                    border-top: 1px solid #e9ecef;
                    padding: 2rem 0;
                }

                /* tag */
                .tag {
                    background: #fff3df;
                    border: 1px solid #ffe0a3;
                    color: #8a5a00;
                    border-radius: 999px;
                    padding: 6px 12px;
                    font-size: .85rem;
                }
            </style>

            <div class="container-fluid px-3 page-wrap">

                <div class="row">

                    <!-- MAIN -->
                    <div class="col-lg-9">

                        <!-- HEADER -->
                        <div class="border-bottom pb-3 mb-4">

                            <h1 class="fw-bold mb-3">
                                <%= question.title %>
                            </h1>

                            <div class="d-flex flex-wrap gap-3 text-muted small">
                                <span>Asked <%= question.createdAt.toLocaleString() %></span>
                                <span>
                                    <%= question.views %> views
                                </span>
                                <span>
                                    <%= question.answersCount %> answers
                                </span>
                            </div>

                        </div>

                        <!-- QUESTION -->
                        <div class="row g-4">

                            <!-- VOTES -->
                            <div class="col-auto">

                                <div class="vote-box d-flex flex-column align-items-center">

                                    <button class="btn btn-light border vote-btn">
                                        ▲
                                    </button>

                                    <div class="fs-3 fw-bold my-2">
                                        <%= question.score %>
                                    </div>

                                    <button class="btn btn-light border vote-btn">
                                        ▼
                                    </button>

                                </div>

                            </div>

                            <!-- CONTENT -->
                            <div class="col">

                                <div class="question-content" id="question-content">
                                    <%- question.content %>
                                </div>

                                <div class="mt-3">
                                    <% question.tags.forEach(tag=> { %>
                                        <span class="tag">
                                            <%= tag.name %>
                                        </span>
                                        <% }) %>
                                </div>

                                <!-- author -->
                                <div class="d-flex justify-content-end mt-4">

                                    <div class="user-mini">

                                        <small class="text-muted">Asked by</small>

                                        <div class="d-flex align-items-center gap-2 mt-2">

                                            <img src="<%= question.creator.profilePicture %>" class="rounded-circle"
                                                width="40" height="40">

                                            <div>
                                                <div class="fw-semibold text-dark text-decoration-none">
                                                    <a href="/users/<%= question.creator._id %>">
                                                        <%= question.creator.displayName %>
                                                    </a>
                                                </div>
                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- ANSWERS -->
                        <h2 class="h4 mt-5 mb-4">
                            <%= comments.length %> Answers
                        </h2>

                        <% comments.forEach(c=> { %>

                            <div class="answer-item">

                                <div class="row g-4">

                                    <!-- VOTES -->
                                    <div class="col-auto">

                                        <div class="d-flex flex-column align-items-center">

                                            <button class="btn btn-light border vote-btn">
                                                ▲
                                            </button>

                                            <div class="fw-bold my-2">
                                                <%= c.score %>
                                            </div>

                                            <button class="btn btn-light border vote-btn">
                                                ▼
                                            </button>

                                        </div>

                                    </div>

                                    <!-- CONTENT -->
                                    <div class="col">

                                        <% if(c.accepted){ %>
                                            <div class="text-success fw-semibold mb-2">
                                                ✓ Accepted Answer
                                            </div>
                                            <% } %>

                                                <div class="answer-content">
                                                    <%- c.content %>
                                                </div>

                                                <div class="d-flex justify-content-end mt-4">

                                                    <div class="user-mini">

                                                        <small class="text-muted">
                                                            Answered <%= c.createdAt %>
                                                        </small>

                                                        <div class="d-flex align-items-center gap-2 mt-2">

                                                            <img src="<%= c.creator.profilePicture %>"
                                                                class="rounded-circle" width="36" height="36">

                                                            <span class="fw-semibold">
                                                                <%= c.creator.username %>
                                                            </span>

                                                        </div>

                                                    </div>

                                                </div>

                                    </div>

                                </div>

                            </div>

                            <% }) %>
                            <% if(!user){ %>
                                <div class="alert alert-info mt-4">
                                    <i class="bi bi-info-circle me-2"></i>
                                    You need to <a href="/login" class="alert-link">log in</a> to post an answer.
                                </div>
                                <% } else { %>

                                <!-- FORM -->
                                <div class="card border-0 shadow-sm mt-5">
                                    <div class="card-body p-4">
                                        <h3 class="h5 mb-3">Your Answer</h3>
                                        <form>
                                            <textarea class="form-control mb-3 imageUploadable" rows="8"
                                                placeholder="Write your answer..."></textarea>
                                            <div class="d-flex justify-content-between align-items-center">

                                                <small class="text-muted">
                                                    Markdown supported
                                                </small>
                                                <button class="btn btn-primary px-4">
                                                    Post Answer
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <% } %>

                    </div>

                    <!-- SIDEBAR -->
                    <div class="col-lg-3">

                        <div class="sticky-top" style="top:90px;">

                            <div class="card mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold">Related</h6>
                                    <small class="text-muted">
                                        • How to center a div flexbox<br>
                                        • CSS grid vs flexbox<br>
                                        • Center absolute div
                                    </small>
                                </div>
                            </div>

                            <div class="card">
                                <div class="card-body">
                                    <h6 class="fw-bold">Tags</h6>
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <% question.tags.forEach(tag=> { %>
                                            <span class="tag">
                                                <%= tag.name %>
                                            </span>
                                            <% }) %>
                                    </div>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>
                <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

            <script src="/js/prism.js"></script>
            <link rel="stylesheet" href="/css/prism.css">
                <%- include('./partials/footer') %>

   
    </body>