<%- include('./partials/header') %>

<body>
    <%- include('./partials/menu', { activePage: 'questions', pageType: 'main' }) %>

    <style>
        .page-wrap { max-width: 1100px; margin: 0 auto; }

        .question-content, .answer-content { font-size: 1.05rem; line-height: 1.8; }
        .question-content p, .answer-content p { margin-bottom: 1rem; }

        .question-content pre, .answer-content pre {
            background: #0d1117; border: 1px solid #30363d; color: #fff;
            padding: 1.25rem; border-radius: 10px; overflow-x: auto;
        }

        .vote-box { position: sticky; top: 90px; }
        .vote-btn { width: 48px; height: 48px; border-radius: 50%; }
        .vote-btn.active-vote { background: #0d6efd; color: #fff; border-color: #0d6efd; }

        .user-mini {
            background: #f8f9fa; border: 1px solid #dee2e6;
            border-radius: 10px; padding: 12px; min-width: 220px;
        }

        .answer-item { border-top: 1px solid #e9ecef; padding: 2rem 0; }
        .answer-item.accepted-answer { border-left: 4px solid #198754; background: #f8fff9; }

        .tag {
            background: #fff3df; border: 1px solid #ffe0a3; color: #8a5a00;
            border-radius: 999px; padding: 6px 12px; font-size: .85rem;
        }

        #answerTabsContent { min-height: 220px; }
        #write-pane textarea { height: 220px; resize: none; box-shadow: none; }
        #preview-pane .answer-content { height: 220px; overflow-y: auto; padding: 0.5rem 0.25rem 0; }
        #preview-pane .answer-content p:last-child { margin-bottom: 0; }
        #textTools .text-tool-btn { width: 40px; }
    </style>

    <div class="container-fluid px-3 page-wrap">
        <div class="row">

            <!-- MAIN -->
            <div class="col-lg-9">

                <!-- HEADER -->
                <div class="border-bottom pb-3 mb-4">
                    <h1 class="fw-bold mb-3"><%= question.title %></h1>

                    <div class="d-flex flex-wrap align-items-center gap-3 text-muted small">
                        <span>Asked <%= question.createdAt.toLocaleString() %></span>
                        <span><%= question.views %> views</span>
                        <span><%= question.answersCount %> answers</span>

                        <% if (isSelf) { %>
                            <div class="d-flex gap-2 ms-auto">
                                <a href="/questions/edit/<%= question._id %>" class="btn btn-outline-primary btn-sm">
                                    <i class="fa-solid fa-pen"></i> Edit Question
                                </a>
                                <button type="button" class="btn btn-outline-danger btn-sm" id="deleteQuestionBtn">
                                    <i class="fa-solid fa-trash"></i> Delete Question
                                </button>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- QUESTION -->
                <div class="row g-4">

                    <!-- VOTES -->
                    <div class="col-auto">
                        <div class="vote-box d-flex flex-column align-items-center">
                            <button type="button" class="btn btn-light border vote-btn"
                                data-type="question" data-id="<%= question._id %>" data-vote="upvote"
                                <%= !user ? 'disabled' : '' %>>
                                ▲
                            </button>

                            <div class="fs-3 fw-bold my-2 question-score"><%= question.score %></div>

                            <button type="button" class="btn btn-light border vote-btn"
                                data-type="question" data-id="<%= question._id %>" data-vote="downvote"
                                <%= !user ? 'disabled' : '' %>>
                                ▼
                            </button>
                        </div>
                    </div>

                    <!-- CONTENT -->
                    <div class="col">
                        <div class="question-content" id="question-content">
                            <%- question.content %>
                        </div>

                        <div class="mt-3">
                            <% question.tags.forEach(tag => { %>
                                <span class="tag"><%= tag.name %></span>
                            <% }) %>
                        </div>

                        <!-- author -->
                        <div class="d-flex justify-content-end mt-4">
                            <div class="user-mini">
                                <small class="text-muted">Asked by</small>
                                <div class="d-flex align-items-center gap-2 mt-2">
                                    <img src="<%= question.creator.profilePicture %>" class="rounded-circle" width="40" height="40">
                                    <div>
                                        <div class="fw-semibold text-dark text-decoration-none">
                                            <a href="/users/<%= question.creator._id %>">
                                                <%= question.creator.displayName %>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- QUESTION COMMENTS -->
                        <div class="mt-4 pt-4 border-top">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-semibold mb-0"><%= question.comments?.length || 0 %> Comments</h6>

                                <% if (user) { %>
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none" type="button"
                                        data-bs-toggle="collapse" data-bs-target="#question-comment-form"
                                        aria-expanded="false" aria-controls="question-comment-form">
                                        Add a comment
                                    </button>
                                <% } %>
                            </div>

                            <% if (question.comments && question.comments.length > 0) { %>
                                <div class="d-flex flex-column gap-2 mb-3">
                                    <% question.comments.forEach(comment => { %>
                                        <div class="bg-light border rounded-3 p-3" id="question-comment-<%= comment._id %>">
                                            <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                                                <div class="d-flex align-items-center gap-2">
                                                    <img src="<%= comment.creator.profilePicture %>" class="rounded-circle" width="24" height="24">
                                                    <a href="/users/<%= comment.creator._id %>" class="fw-semibold small text-decoration-none">
                                                        <%= comment.creator.displayName || comment.creator.username %>
                                                    </a>
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <small class="text-muted">
                                                        <%= comment.createdAt.toLocaleString() %><%= comment.isEdited ? ' (edited)' : '' %>
                                                    </small>

                                                    <% if (user && comment.creator._id.toString() === user._id.toString()) { %>
                                                        <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none"
                                                            data-bs-toggle="collapse" data-bs-target="#edit-question-comment-<%= comment._id %>">
                                                            <i class="fa-solid fa-pen small"></i>
                                                        </button>
                                                        <button type="button"
                                                            class="btn btn-link btn-sm p-0 text-decoration-none text-danger delete-question-comment-btn"
                                                            data-question-id="<%= question._id %>" data-comment-id="<%= comment._id %>">
                                                            <i class="fa-solid fa-trash small"></i>
                                                        </button>
                                                    <% } %>
                                                </div>
                                            </div>

                                            <div class="small text-break"><%= comment.content %></div>

                                            <% if (user && comment.creator._id.toString() === user._id.toString()) { %>
                                                <div class="collapse mt-2" id="edit-question-comment-<%= comment._id %>">
                                                    <textarea class="form-control form-control-sm mb-2 edit-question-comment-textarea"
                                                        rows="2" maxlength="500"><%= comment.content %></textarea>
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button type="button" class="btn btn-sm btn-secondary"
                                                            data-bs-toggle="collapse" data-bs-target="#edit-question-comment-<%= comment._id %>">
                                                            Cancel
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-primary save-edit-question-comment-btn"
                                                            data-question-id="<%= question._id %>" data-comment-id="<%= comment._id %>">
                                                            Save
                                                        </button>
                                                    </div>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p class="text-muted small mb-3">No comments yet.</p>
                            <% } %>

                            <% if (user) { %>
                                <div class="collapse" id="question-comment-form">
                                    <form class="question-comment-form" data-question-id="<%= question._id %>">
                                        <div class="mb-2">
                                            <textarea class="form-control form-control-sm" rows="2"
                                                placeholder="Write a comment..." maxlength="500" required></textarea>
                                        </div>
                                        <div class="d-flex justify-content-end">
                                            <button type="submit" class="btn btn-outline-primary btn-sm">Post comment</button>
                                        </div>
                                    </form>
                                </div>
                            <% } %>
                        </div>

                    </div>
                </div>

                <!-- ANSWERS -->
                <h2 class="h4 mt-5 mb-4"><%= answers.length %> Answers</h2>

                <% answers.forEach(c => { %>

                    <div class="card shadow-sm border-0 mb-3 answer-item <%= c.isAnswer ? 'accepted-answer' : '' %>">
                        <div class="card-body p-4">
                            <div class="row g-4">

                                <!-- VOTES -->
                                <div class="col-auto">
                                    <div class="d-flex flex-column align-items-center">
                                        <button type="button" class="btn btn-light border vote-btn"
                                            data-type="answer" data-id="<%= c._id %>" data-vote="upvote"
                                            <%= !user ? 'disabled' : '' %>>
                                            ▲
                                        </button>

                                        <div class="fw-bold my-2 answer-score"><%= c.score %></div>

                                        <button type="button" class="btn btn-light border vote-btn"
                                            data-type="answer" data-id="<%= c._id %>" data-vote="downvote"
                                            <%= !user ? 'disabled' : '' %>>
                                            ▼
                                        </button>
                                    </div>
                                </div>

                                <!-- CONTENT -->
                                <div class="col">

                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <% if (c.isAnswer) { %>
                                            <div class="text-success fw-semibold">✓ Accepted Answer</div>
                                        <% } else { %>
                                            <div></div>
                                        <% } %>

                                        <div class="d-flex gap-2">
                                            <% if (isSelf) { %>
                                                <button type="button"
                                                    class="btn btn-sm <%= c.isAnswer ? 'btn-success' : 'btn-outline-success' %> accept-answer-btn"
                                                    data-question-id="<%= question._id %>" data-answer-id="<%= c._id %>">
                                                    <i class="fa-solid fa-check"></i> <%= c.isAnswer ? 'Accepted' : 'Accept' %>
                                                </button>
                                            <% } %>

                                            <% if (user && c.creator._id.toString() === user._id.toString()) { %>
                                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    data-bs-toggle="collapse" data-bs-target="#edit-answer-<%= c._id %>">
                                                    <i class="fa-solid fa-pen"></i> Edit
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-danger delete-answer-btn"
                                                    data-answer-id="<%= c._id %>">
                                                    <i class="fa-solid fa-trash"></i> Delete
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>

                                    <div class="answer-content">
                                        <%- c.content %>
                                    </div>

                                    <% if (c.isEdited) { %>
                                        <small class="text-muted fst-italic">(edited)</small>
                                    <% } %>

                                    <% if (user && c.creator._id.toString() === user._id.toString()) { %>
                                        <div class="collapse mt-3" id="edit-answer-<%= c._id %>">
                                            <textarea class="form-control mb-2 edit-answer-textarea" rows="4"
                                                maxlength="2000"><%= c.content %></textarea>
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="button" class="btn btn-sm btn-secondary"
                                                    data-bs-toggle="collapse" data-bs-target="#edit-answer-<%= c._id %>">
                                                    Cancel
                                                </button>
                                                <button type="button" class="btn btn-sm btn-primary save-edit-answer-btn"
                                                    data-answer-id="<%= c._id %>">
                                                    Save
                                                </button>
                                            </div>
                                        </div>
                                    <% } %>

                                    <div class="d-flex justify-content-end mt-4">
                                        <div class="user-mini">
                                            <small class="text-muted">Answered <%= c.createdAt.toLocaleString() %></small>
                                            <div class="d-flex align-items-center gap-2 mt-2">
                                                <img src="<%= c.creator.profilePicture %>" class="rounded-circle" width="36" height="36">
                                                <span class="fw-semibold"><%= c.creator.username %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ANSWER COMMENTS -->
                                    <div class="mt-4 pt-3 border-top">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <small class="text-muted fw-semibold"><%= c.comments?.length || 0 %> comments</small>

                                            <% if (user) { %>
                                                <button class="btn btn-link btn-sm p-0 text-decoration-none" type="button"
                                                    data-bs-toggle="collapse" data-bs-target="#answer-comment-form-<%= c._id %>"
                                                    aria-expanded="false" aria-controls="answer-comment-form-<%= c._id %>">
                                                    Add a comment
                                                </button>
                                            <% } %>
                                        </div>

                                        <% if (c.comments && c.comments.length > 0) { %>
                                            <div class="d-flex flex-column gap-2">
                                                <% c.comments.forEach(comment => { %>
                                                    <div class="bg-light border rounded-3 p-3" id="answer-comment-<%= comment._id %>">
                                                        <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                                                            <div class="d-flex align-items-center gap-2">
                                                                <img src="<%= comment.creator.profilePicture %>" class="rounded-circle" width="24" height="24">
                                                                <a href="/users/<%= comment.creator._id %>" class="fw-semibold small text-decoration-none">
                                                                    <%= comment.creator.displayName || comment.creator.username %>
                                                                </a>
                                                            </div>
                                                            <div class="d-flex align-items-center gap-2">
                                                                <small class="text-muted">
                                                                    <%= comment.createdAt.toLocaleString() %><%= comment.isEdited ? ' (edited)' : '' %>
                                                                </small>

                                                                <% if (user && comment.creator._id.toString() === user._id.toString()) { %>
                                                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none"
                                                                        data-bs-toggle="collapse" data-bs-target="#edit-answer-comment-<%= comment._id %>">
                                                                        <i class="fa-solid fa-pen small"></i>
                                                                    </button>
                                                                    <button type="button"
                                                                        class="btn btn-link btn-sm p-0 text-decoration-none text-danger delete-answer-comment-btn"
                                                                        data-answer-id="<%= c._id %>" data-comment-id="<%= comment._id %>">
                                                                        <i class="fa-solid fa-trash small"></i>
                                                                    </button>
                                                                <% } %>
                                                            </div>
                                                        </div>

                                                        <div class="small text-break"><%= comment.content %></div>

                                                        <% if (user && comment.creator._id.toString() === user._id.toString()) { %>
                                                            <div class="collapse mt-2" id="edit-answer-comment-<%= comment._id %>">
                                                                <textarea class="form-control form-control-sm mb-2 edit-answer-comment-textarea"
                                                                    rows="2" maxlength="500"><%= comment.content %></textarea>
                                                                <div class="d-flex justify-content-end gap-2">
                                                                    <button type="button" class="btn btn-sm btn-secondary"
                                                                        data-bs-toggle="collapse" data-bs-target="#edit-answer-comment-<%= comment._id %>">
                                                                        Cancel
                                                                    </button>
                                                                    <button type="button" class="btn btn-sm btn-primary save-edit-answer-comment-btn"
                                                                        data-answer-id="<%= c._id %>" data-comment-id="<%= comment._id %>">
                                                                        Save
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        <% } else { %>
                                            <p class="text-muted small mb-0">No comments yet.</p>
                                        <% } %>

                                        <% if (user) { %>
                                            <div class="collapse mt-3" id="answer-comment-form-<%= c._id %>">
                                                <form class="answer-comment-form" data-question-id="<%= question._id %>" data-answer-id="<%= c._id %>">
                                                    <div class="mb-2">
                                                        <textarea class="form-control form-control-sm" rows="2"
                                                            placeholder="Write a comment..." maxlength="500" required></textarea>
                                                    </div>
                                                    <div class="d-flex justify-content-end">
                                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                                            Post comment
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        <% } %>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                <% }) %>

                <% if (!user) { %>
                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle me-2"></i>
                        You need to <a href="/login" class="alert-link">log in</a> to post an answer.
                    </div>
                <% } else { %>

                    <div class="card border-0 shadow-sm mt-5">
                        <div class="card-body p-4">

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="h5 mb-0">Your Answer</h3>
                                <small class="text-muted" id="answerLength">0/2000</small>
                            </div>

                            <div class="btn-toolbar mb-2" id="textTools" role="toolbar">
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="bold" title="Bold">
                                        <i class="fa fa-bold"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="italic" title="Italic">
                                        <i class="fa fa-italic"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="code" title="Code">
                                        <i class="fa fa-code"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="link" title="Link">
                                        <i class="fa fa-link"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="image" title="Image">
                                        <i class="fa fa-image"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="blockquote" title="Quote">
                                        <i class="fa fa-quote-left"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="ul" title="Bullet list">
                                        <i class="fa fa-list-ul"></i>
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary text-tool-btn" data-action="ol" title="Numbered list">
                                        <i class="fa fa-list-ol"></i>
                                    </button>
                                </div>
                            </div>

                            <ul class="nav nav-tabs" id="answerTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="write-tab" data-bs-toggle="tab"
                                        data-bs-target="#write-pane" type="button" role="tab"
                                        aria-controls="write-pane" aria-selected="true">
                                        <i class="fa fa-pen me-1"></i> Write
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="preview-tab" data-bs-toggle="tab"
                                        data-bs-target="#preview-pane" type="button" role="tab"
                                        aria-controls="preview-pane" aria-selected="false">
                                        <i class="fa fa-eye me-1"></i> Preview
                                    </button>
                                </li>
                            </ul>

                            <div class="tab-content border border-top-0 rounded-bottom p-3 mb-3" id="answerTabsContent">
                                <div class="tab-pane fade show active" id="write-pane" role="tabpanel" aria-labelledby="write-tab">
                                    <textarea class="form-control border-0 p-0 imageUploadable"
                                        placeholder="Write your answer..." id="answeInput"></textarea>
                                </div>

                                <div class="tab-pane fade" id="preview-pane" role="tabpanel" aria-labelledby="preview-tab">
                                    <div class="answer-content" id="previewContent">
                                        <p class="text-muted mb-0">Nothing to preview yet...</p>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    Markdown supported, paste images directly into the editor.
                                </small>
                                <button type="button" class="btn btn-primary px-4" id="answerbtn"
                                    data-question-id="<%= question._id %>" disabled>
                                    Post Answer
                                </button>
                            </div>

                        </div>
                    </div>
                <% } %>

            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-3">
                <div class="sticky-top" style="top:90px;">

                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold">Related</h6>
                            <small class="text-muted">
                                • How to center a div flexbox<br>
                                • CSS grid vs flexbox<br>
                                • Center absolute div
                            </small>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-body">
                            <h6 class="fw-bold">Tags</h6>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                <% question.tags.forEach(tag => { %>
                                    <span class="tag"><%= tag.name %></span>
                                <% }) %>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
        <script src="/js/prism.js"></script>
        <link rel="stylesheet" href="/css/prism.css">
        <script src="/js/questions.js" defer></script>

        <%- include('./partials/footer') %>

    </div>

</body>