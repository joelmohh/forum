                                            <!-- Answer Content -->
                                            <div class="col-12 col-md-11">
                                                <p class="mb-3"><strong>Use Flexbox:</strong> This is the modern and
                                                    most flexible way to center content.</p>

                                                <pre
                                                    style="background: #f4f5f6; padding: 12px; border-radius: 4px; overflow-x: auto;"><code>.container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}</code></pre>

                                                <p class="mb-3">This will center your div both horizontally and
                                                    vertically. The <code>justify-content</code> handle horizontal
                                                    centering and <code>align-items</code> handles vertical centering.
                                                </p>

                                                <div class="alert alert-info small mb-3">
                                                    <strong>Tip:</strong> You can also use CSS Grid for the same result
                                                    with <code>display: grid; place-items: center;</code>
                                                </div>

